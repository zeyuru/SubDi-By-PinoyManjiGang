Options -Indexes
RewriteEngine On

# 1. Set the Base to your actual project folder
RewriteBase /SubDi-By-PinoyManjiGang/villa_purita/

# 2. If the file or folder actually exists (like images/css), just serve it
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 3. Otherwise, send the request to your api/index.php
RewriteRule ^api/(.*)$ api/index.php [QSA,L]